<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= appName %> - Create Incident</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    * { box-sizing: border-box; }
    body { margin:0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f7fb; }
    .layout { display:flex; min-height:100vh; }
    .create-sidebar { width: 260px; background:#fff; border-right:1px solid #e6edf3; padding:24px; }
    .brand { font-weight:700; color:#0f766e; margin-bottom:12px; }
    .workflow-step { display:flex; gap:12px; align-items:center; padding:12px 10px; border-radius:6px; cursor:pointer; color:#64748b; margin-bottom:8px; }
    .workflow-step .num { width:28px;height:28px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;background:#eef2f6;color:#64748b;font-weight:700; }
    .workflow-step.active { background:#f0fdf4; color:#065f56; }
    .workflow-step.active .num { background:#0f766e;color:#fff; }
    .workflow-step.completed { background:#f8faf7;color:#065f56; }

    .create-main { flex:1; padding: 28px 40px; }
    .page-header { display:flex;justify-content:space-between;align-items:center;margin-bottom:20px; }
    .page-header h1 { margin:0; font-size:20px; color:#0f172a; }
    .form-panel { background:#fff; border-radius:8px; padding:28px; box-shadow:0 6px 20px rgba(2,6,23,0.06); }
    .step-panel { display:none; }
    .step-panel.active { display:block; }
    .field { margin-bottom:16px; }
    label { display:block; font-size:13px;color:#334155;margin-bottom:6px; font-weight:600; }
    input[type="text"], select, textarea { width:100%; padding:12px;border:1px solid #e6edf3;border-radius:6px;font-size:14px;background:#fff; }
    textarea { min-height:140px; resize:vertical; }
    .file-drop { padding:12px;border:2px dashed #e6edf3;border-radius:6px;text-align:center;background:#fbfdff;cursor:pointer; }
    .file-drop.drag { border-color:#0f766e;background:#f0fdf4; }
    .file-preview { margin-top:10px; display:none; align-items:flex-start; gap:12px; padding:10px; border:1px solid #e2e8f0; border-radius:8px; background:#f8fafc; }
    .file-preview img { width:120px; height:80px; object-fit:cover; border-radius:6px; border:1px solid #dbe5f1; background:#fff; }
    .file-preview-meta { font-size:12px; color:#64748b; line-height:1.4; }
    .file-preview-actions { margin-top:8px; }
    .remove-attachment {
      border: none;
      background: #fee2e2;
      color: #b91c1c;
      border-radius: 999px;
      width: 28px;
      height: 28px;
      font-size: 16px;
      line-height: 1;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0;
    }
    .remove-attachment:hover { background: #fecaca; }
    .actions { display:flex; gap:12px; justify-content:flex-end; margin-top:20px; }
    .btn { padding:10px 16px; border-radius:8px; font-weight:700; cursor:pointer; border:none; }
    .btn.secondary { background:#f1f5f9; color:#334155; }
    .btn.primary { background:#0f766e; color:#fff; }
    .meta-grid { display:grid; grid-template-columns: 1fr 1fr; gap:12px; margin-top:12px; }
    .review-row { padding:12px;border-radius:6px;background:#fbfdff;border:1px solid #eef2f6;margin-bottom:8px; }
    @media (max-width:900px){ .create-sidebar{display:none} .create-main{padding:16px} }
  </style>
</head>
<body>
  <div class="layout">
    <div class="create-sidebar">
      <div class="brand">Create Incident</div>
      <div id="s1" class="workflow-step active" data-step="1" onclick="goToStep(1)">
        <div class="num">1</div>
        <div>Basic Information</div>
      </div>
      <div id="s2" class="workflow-step" data-step="2" onclick="goToStep(2)">
        <div class="num">2</div>
        <div>Details</div>
      </div>
      <div id="s3" class="workflow-step" data-step="3" onclick="goToStep(3)">
        <div class="num">3</div>
        <div>Assignment</div>
      </div>
      <div id="s4" class="workflow-step" data-step="4" onclick="goToStep(4)">
        <div class="num">4</div>
        <div>Review & Create</div>
      </div>
    </div>

    <div class="create-main">
      <div class="page-header">
        <h1>Create New Incident</h1>
        <div style="color:#64748b">Complete required fields to route to the correct team</div>
      </div>

      <div class="form-panel">
        <form id="incidentForm" action="/report" method="POST" enctype="multipart/form-data">
          <!-- Step 1 -->
          <div id="step-1" class="step-panel active">
            <h3>Step 1 — Basic Information</h3>
            <p style="color:#64748b;margin-top:6px;">Incident Title and priority</p>
            <div class="field">
              <label for="title">Incident Title *</label>
              <input id="title" name="title" type="text" placeholder="Briefly describe the issue" required />
            </div>
            <div class="field">
              <label for="priority">Priority Level *</label>
              <select id="priority" name="priority" required>
                <option value="">— Select Priority —</option>
                <option value="Low">Low — Minimal impact (SLA: 120h)</option>
                <option value="Medium">Medium — Moderate impact (SLA: 72h)</option>
                <option value="High">High — Significant impact (SLA: 24h)</option>
                <option value="Critical">Critical — Urgent / Severe (SLA: 4h)</option>
              </select>
              <div id="slaHint" style="margin-top:8px;color:#64748b;font-size:12px;">
                SLA target will be calculated from ticket creation time.
              </div>
            </div>
            <div class="actions">
              <button type="button" class="btn secondary" onclick="window.location='/incidents'">Cancel</button>
              <button type="button" class="btn primary" onclick="nextStep()">Next</button>
            </div>
          </div>

          <!-- Step 2 -->
          <div id="step-2" class="step-panel">
            <h3>Step 2 — Detailed Description</h3>
            <p style="color:#64748b;margin-top:6px;">Provide expected vs actual behavior and context</p>
            <div class="field">
              <label for="description">Description of Issue *</label>
              <textarea id="description" name="description" placeholder="Provide detailed information" required></textarea>
            </div>
            <div class="field">
              <label for="screenshot">Attach Screenshot (optional)</label>
              <div class="file-drop" id="fileDrop" role="button" tabindex="0" aria-label="Upload screenshot">📎 Click to upload or drag & drop</div>
              <input id="screenshot" name="screenshot" type="file" accept="image/*" style="display:none" />
              <div id="fileName" style="margin-top:8px;color:#64748b;font-size:13px"></div>
              <div id="filePreview" class="file-preview" aria-live="polite">
                <img id="filePreviewImg" alt="Selected screenshot preview" />
                <div class="file-preview-meta">
                  <div id="filePreviewMeta"></div>
                  <div class="file-preview-actions">
                    <button id="removeAttachment" type="button" class="remove-attachment" aria-label="Remove selected screenshot" title="Remove attachment">×</button>
                  </div>
                </div>
              </div>
            </div>
            <div class="actions">
              <button type="button" class="btn secondary" onclick="window.location='/incidents'">Cancel</button>
              <button type="button" class="btn secondary" onclick="prevStep()">Back</button>
              <button type="button" class="btn primary" onclick="nextStep()">Next</button>
            </div>
          </div>

          <!-- Step 3 -->
          <div id="step-3" class="step-panel">
            <h3>Step 3 — Assignment</h3>
            <p style="color:#64748b;margin-top:6px;">(Optional) Assign to a team or yourself</p>
            <div class="field">
              <label for="assignee">Assign To</label>
              <select id="assignee" name="assignee">
                <option value="">— No assignment —</option>
                <% if (currentUser && currentUser !== 'guest') { %>
                  <option value="<%= currentUser %>">Assign to me (<%= currentUser %>)</option>
                <% } %>
                <option value="support-team">Support Team</option>
                <option value="dev-team">Development Team</option>
                <option value="qa-team">QA Team</option>
              </select>
            </div>
            <div class="actions">
              <button type="button" class="btn secondary" onclick="window.location='/incidents'">Cancel</button>
              <button type="button" class="btn secondary" onclick="prevStep()">Back</button>
              <button type="button" class="btn primary" onclick="goToStep(4)">Review</button>
            </div>
          </div>

          <!-- Step 4: Review -->
          <div id="step-4" class="step-panel">
            <h3>Step 4 — Review & Create</h3>
            <p style="color:#64748b;margin-top:6px;">Confirm information below before creating the incident</p>
            <div id="reviewArea" style="margin-top:12px;"></div>

            <div class="actions">
              <button type="button" class="btn secondary" onclick="window.location='/incidents'">Cancel</button>
              <button type="button" class="btn secondary" onclick="prevStep()">Back</button>
              <button id="create-incident-submit" type="submit" class="btn primary">Create Incident</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
    const steps = [1,2,3,4];
    let current = 1;

    const priorityToSlaHours = {
      Critical: 4,
      High: 24,
      Medium: 72,
      Low: 120
    };

    function updateSlaHint() {
      const priority = document.getElementById('priority')?.value;
      const hint = document.getElementById('slaHint');
      if (!hint) return;
      if (!priority || !priorityToSlaHours[priority]) {
        hint.textContent = 'SLA target will be calculated from ticket creation time.';
        return;
      }
      hint.textContent = `Selected ${priority} priority: SLA target is ${priorityToSlaHours[priority]} hours from creation.`;
    }

    function updateSidebar() {
      steps.forEach(s => {
        const el = document.getElementById('s'+s);
        if (!el) return;
        el.classList.remove('active'); el.classList.remove('completed');
        if (s < current) el.classList.add('completed');
        if (s === current) el.classList.add('active');
      });
    }

    function showStep(n) {
      steps.forEach(s => {
        const panel = document.getElementById('step-'+s);
        if (!panel) return;
        panel.classList.toggle('active', s === n);
      });
      current = n;
      updateSidebar();
      if (n === 4) renderReview();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function goToStep(n){
      showStep(n);
    }

    document.getElementById('priority')?.addEventListener('change', updateSlaHint);
    updateSlaHint();

    function nextStep(){
      if (!validateStep(current)) return;
      const idx = steps.indexOf(current);
      if (idx < steps.length-1) showStep(steps[idx+1]);
    }

    function prevStep(){
      const idx = steps.indexOf(current);
      if (idx > 0) showStep(steps[idx-1]);
    }

    function validateStep(n){
      if (n === 1) {
        const title = document.getElementById('title').value.trim();
        const priority = document.getElementById('priority').value;
        if (!title || !priority) { alert('Please fill required fields in Basic Information.'); return false; }
      }
      if (n === 2) {
        const desc = document.getElementById('description').value.trim();
        if (!desc) { alert('Please provide a detailed description.'); return false; }
      }
      return true;
    }

    // file input handlers
    const fileDrop = document.getElementById('fileDrop');
    const fileInput = document.getElementById('screenshot');
    const fileName = document.getElementById('fileName');
    const filePreview = document.getElementById('filePreview');
    const filePreviewImg = document.getElementById('filePreviewImg');
    const filePreviewMeta = document.getElementById('filePreviewMeta');
    const removeAttachment = document.getElementById('removeAttachment');
    const incidentForm = document.getElementById('incidentForm');
    const createIncidentSubmit = document.getElementById('create-incident-submit');
    let activePreviewUrl = null;

    function revokePreviewUrl() {
      if (activePreviewUrl) {
        URL.revokeObjectURL(activePreviewUrl);
        activePreviewUrl = null;
      }
    }

    function clearPreview() {
      revokePreviewUrl();
      fileInput.value = '';
      fileName.textContent = '';
      filePreview.style.display = 'none';
      filePreviewImg.removeAttribute('src');
      filePreviewMeta.textContent = '';
    }

    function formatFileSize(bytes) {
      if (!bytes && bytes !== 0) return '';
      if (bytes < 1024) return `${bytes} B`;
      if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
      return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
    }

    function renderPreview(file) {
      if (!file || !file.type || !file.type.startsWith('image/')) {
        clearPreview();
        return;
      }
      revokePreviewUrl();
      activePreviewUrl = URL.createObjectURL(file);
      filePreviewImg.src = activePreviewUrl;
      filePreviewMeta.innerHTML = `<strong style="color:#334155">${escapeHtml(file.name)}</strong><br>${formatFileSize(file.size)} • ${escapeHtml(file.type)}`;
      filePreview.style.display = 'flex';
    }

    function openFilePicker() {
      fileInput.click();
    }

    fileDrop.addEventListener('click', openFilePicker);
    fileDrop.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        openFilePicker();
      }
    });
    fileInput.addEventListener('change', () => {
      if (fileInput.files.length) {
        const selectedFile = fileInput.files[0];
        fileName.textContent = selectedFile.name;
        renderPreview(selectedFile);
      } else {
        fileName.textContent = '';
        clearPreview();
      }
    });
    fileDrop.addEventListener('dragover', e => { e.preventDefault(); fileDrop.classList.add('drag'); });
    fileDrop.addEventListener('dragleave', e => { e.preventDefault(); fileDrop.classList.remove('drag'); });
    fileDrop.addEventListener('drop', e => {
      e.preventDefault();
      fileDrop.classList.remove('drag');
      const f = e.dataTransfer.files[0];
      if (f) {
        fileInput.files = e.dataTransfer.files;
        fileName.textContent = f.name;
        renderPreview(f);
      }
    });

    removeAttachment.addEventListener('click', clearPreview);

    if (incidentForm && createIncidentSubmit) {
      incidentForm.addEventListener('submit', () => {
        createIncidentSubmit.disabled = true;
        createIncidentSubmit.textContent = 'Creating...';
      });
    }

    window.addEventListener('beforeunload', revokePreviewUrl);

    function renderReview(){
      const r = document.getElementById('reviewArea');
      const title = document.getElementById('title').value.trim();
      const priority = document.getElementById('priority').value;
      const description = document.getElementById('description').value.trim();
      const assignee = document.getElementById('assignee').value;
      const screenshot = fileInput.files[0] ? fileInput.files[0].name : '—';
      r.innerHTML = '';
      r.innerHTML += `<div class="review-row"><strong>Title:</strong><div style="margin-top:6px">${escapeHtml(title)}</div></div>`;
      r.innerHTML += `<div class="review-row"><strong>Priority:</strong><div style="margin-top:6px">${escapeHtml(priority)}</div></div>`;
      r.innerHTML += `<div class="review-row"><strong>Description:</strong><div style="margin-top:6px">${escapeHtml(description)}</div></div>`;
      r.innerHTML += `<div class="review-row"><strong>Assignee:</strong><div style="margin-top:6px">${escapeHtml(assignee || 'Unassigned')}</div></div>`;
      r.innerHTML += `<div class="review-row"><strong>Attachment:</strong><div style="margin-top:6px">${escapeHtml(screenshot)}</div></div>`;
    }

    function escapeHtml(str){ return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    // initialize
    updateSidebar();
    showStep(1);
  </script>
</body>
</html>
