<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= appName %> - Incident & Service Dashboard</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    .layout {
      display: flex;
      min-height: 100vh;
    }
    .sidebar {
      width: 220px;
      background: #0f172a;
      color: #fff;
      display: flex;
      flex-direction: column;
      padding: 32px 0 0 0;
      min-height: 100vh;
      box-shadow: 2px 0 12px rgba(0,0,0,0.04);
    }
    .sidebar .logo {
      font-size: 1.6em;
      font-weight: bold;
      margin-bottom: 32px;
      text-align: center;
      letter-spacing: 1px;
    }
    .sidebar nav {
      display: flex;
      flex-direction: column;
      gap: 18px;
      margin-left: 24px;
    }
    .sidebar nav a {
      color: #cbd5e1;
      text-decoration: none;
      font-size: 1.1em;
      padding: 8px 0;
      border-left: 4px solid transparent;
      transition: color 0.2s, border-color 0.2s;
    }
    .sidebar nav a.active, .sidebar nav a:hover {
      color: #38bdf8;
      border-left: 4px solid #38bdf8;
      background: rgba(56,189,248,0.08);
    }
    .main-content {
      flex: 1;
      background: #f5f7fb;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    .navbar {
      background: #fff;
      padding: 18px 32px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .navbar .app-title {
      font-size: 1.3em;
      font-weight: 600;
      color: #0f172a;
      letter-spacing: 1px;
    }
    .dashboard-kpis {
      display: flex;
      gap: 24px;
      margin: 32px 0 24px 0;
    }
    .kpi-card {
      background: #fff;
      border-radius: 10px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
      padding: 24px 32px;
      min-width: 180px;
      text-align: center;
      flex: 1;
    }
    .kpi-label {
      color: #64748b;
      font-size: 1em;
      margin-bottom: 8px;
    }
    .kpi-value {
      font-size: 2.2em;
      font-weight: bold;
      color: #0f766e;
    }
    .recent-table {
      width: 100%;
      border-collapse: collapse;
      background: #fff;
      border-radius: 10px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
      margin-bottom: 32px;
      overflow: hidden;
    }
    .recent-table th, .recent-table td {
      padding: 14px 18px;
      text-align: left;
    }
    .recent-table th {
      background: #f1f5f9;
      color: #334155;
      font-weight: 600;
    }
    .recent-table tr:not(:last-child) {
      border-bottom: 1px solid #e5e7eb;
    }
    .status-badge { display: inline-block; padding: 4px 8px; border-radius: 3px; font-size: 12px; font-weight: bold; margin-right: 8px; }
    .status-OPEN { background: #ffc107; color: #000; }
    .status-ASSIGNED { background: #17a2b8; color: white; }
    .status-IN_PROGRESS { background: #0275d8; color: white; }
    .status-RESOLVED { background: #28a745; color: white; }
    .status-CLOSED { background: #6c757d; color: white; }
    .filter-bar { margin: 15px 0; }
    .filter-bar a { padding: 8px 12px; margin-right: 8px; background: #f0f0f0; text-decoration: none; border-radius: 4px; }
    .filter-bar a.active { background: #007bff; color: white; }
    @media (max-width: 900px) {
      .layout { flex-direction: column; }
      .sidebar { width: 100%; min-height: unset; flex-direction: row; padding: 0; }
      .sidebar nav { flex-direction: row; margin-left: 0; gap: 8px; }
      .main-content { padding: 0 8px; }
      .dashboard-kpis { flex-direction: column; gap: 12px; }
    }
  </style>
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <div class="logo">
        <img src="/favicon.svg" alt="logo" style="height:32px;vertical-align:middle;margin-right:8px;"/>
        <%= appName %>
      </div>
      <nav>
        <a href="#" class="active">Dashboard</a>
        <a href="#incidents">Incidents</a>
        <a href="#services">Services</a>
      </nav>
    </aside>
    <div class="main-content">
      <div class="navbar">
        <span class="app-title">Incident & Service Operations Dashboard</span>
        <span style="color:#64748b;font-size:1em;">Welcome<% if (currentUser && currentUser !== 'guest') { %>, <%= currentUser %><% } %></span>
      </div>
      <div style="padding: 32px;">
        <!-- Dashboard KPI Cards -->
        <div class="dashboard-kpis">
          <a href="/?filter=open" style="text-decoration:none;" class="kpi-card">
            <div class="kpi-label">Open Incidents</div>
            <div class="kpi-value"><%= kpiOpen || 0 %></div>
          </a>
          <a href="/?filter=resolvedToday" style="text-decoration:none;" class="kpi-card">
            <div class="kpi-label">Resolved Today</div>
            <div class="kpi-value"><%= kpiResolvedToday || 0 %></div>
          </a>
          <a href="/?filter=critical" style="text-decoration:none;" class="kpi-card">
            <div class="kpi-label">Critical Issues</div>
            <div class="kpi-value"><%= kpiCritical || 0 %></div>
          </a>
          <a href="#services" style="text-decoration:none;" class="kpi-card">
            <div class="kpi-label">Active Services</div>
            <div class="kpi-value">4</div>
          </a>
        </div>

        <!-- Recent Incidents Table -->
        <h2 style="margin-top:0;">Recent Incidents</h2>
        <table class="recent-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Title</th>
              <th>Status</th>
              <th>Priority</th>
              <th>Assignee</th>
              <th>Created</th>
            </tr>
          </thead>
          <tbody>
            <% reports.slice(0, 5).forEach(function(report) { %>
              <tr onclick="window.location='/report/<%= report.id %>'" style="cursor:pointer;">
                <td>#<%= report.id %></td>
                <td><%= report.title %></td>
                <% if (report.status) { %>
                  <td><span class="status-badge status-<%= report.status %>"><%= report.status.replace('_',' ') %></span></td>
                <% } else { %>
                  <td><span class="status-badge status-OPEN">OPEN</span></td>
                <% } %>
                <td><%= report.priority %></td>
                <td><%= report.assignee || 'Unassigned' %></td>
                <td><%= new Date(report.createdAt).toLocaleString() %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>

        <!-- Incident Form -->
        <h2 id="incidents">Create Incident</h2>
        <form action="/report" method="POST" enctype="multipart/form-data" class="report-form">
          <input type="text" name="title" placeholder="Incident title" required />
          <select name="priority" required>
            <option value="">Select priority</option>
            <option value="Low">Low</option>
            <option value="Medium">Medium</option>
            <option value="High">High</option>
            <option value="Critical">Critical</option>
          </select>
          <textarea name="description" placeholder="Describe the issue" rows="5" required></textarea>
          <input type="file" name="screenshot" />
          <label style="display:block;margin-top:8px;">Assign to:
            <select name="assignee">
              <option value="">-- Unassigned --</option>
              <% if (currentUser && currentUser !== 'guest') { %>
                <option value="<%= currentUser %>" selected>Assign to me</option>
              <% } %>
              <option value="support-team">Support Team</option>
              <option value="dev-team">Dev Team</option>
              <option value="qa-team">QA Team</option>
            </select>
          </label>
          <button type="submit">Submit Incident</button>
        </form>

        <!-- Incident Filters and List -->
        <h2>All Incidents</h2>
        <div class="filter-bar">
          <a href="/?filter=all" class="<%= filter === 'all' || !filter ? 'active' : '' %>">All Reports</a>
          <a href="/?filter=myIncidents" class="<%= filter === 'myIncidents' ? 'active' : '' %>">My Incidents</a>
        </div>
        <% reports.forEach(function(report) { %>
          <div class="card" onclick="window.location='/report/<%= report.id %>'" style="cursor:pointer;">
            <div style="display:flex;align-items:center;justify-content:space-between;">
              <div>
                <% if (report.status) { %>
                  <span class="status-badge status-<%= report.status %>"><%= report.status.replace('_',' ') %></span>
                <% } else { %>
                  <span class="status-badge status-OPEN">OPEN</span>
                <% } %>
                <b>#<%= report.id %> — <%= report.title %></b>
              </div>
              <span style="color:#64748b;font-size:0.95em;">Reporter: <%= report.reporter %></span>
            </div>
            <div style="margin:8px 0 4px 0;">
              <b>Priority:</b> <%= report.priority %>
            </div>
            <div><%= report.description %></div>
            <% if (report.screenshot) { %>
              <div style="margin-top:8px;">
                <b>Bug screenshot</b><br/>
                <img src="<%= report.screenshot %>" alt="screenshot" style="max-width:220px;max-height:120px;" onerror="this.style.display='none'" />
              </div>
            <% } %>
            <div style="margin-top:8px;color:#64748b;font-size:0.95em;">
              <%= new Date(report.createdAt).toLocaleString() %>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</body>
</html>
