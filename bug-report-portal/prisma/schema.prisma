generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum BugStatus {
  OPEN
  UNASSIGNED
  ASSIGNED
  IN_PROGRESS
  ON_HOLD
  RESOLVED
  CLOSED
  REOPENED
}

model BugReport {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  priority    String
  reporter    String
  screenshot  String?
  status      BugStatus @default(OPEN)
  assignee    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  resolvedAt  DateTime?
}